                "target": "Modular Arithmetic",
                "type": "uses"
            }
        ],
        "operations": [
            "Enqueue(x): Enqueue, insert x at rear",
            "Dequeue(): Dequeue, remove front",
            "Front(): Access front element",
            "IsEmpty(): Check if queue is empty",
            "IsFull(): Check if queue is full",
            "Size(): Check the size of the queue"
        ],
        "related_topics": [
            "Queue",
            "Array",
            "Linked List"
        ],
        "code_examples": {
            "cpp": [
                "#include <iostream>",
                "using namespace std;",
                "",
                "int arr[3], front = -1, rear = -1, n = 3;",
                "",
                "void enqueue(int x) {",
                "    if ((rear + 1) % n == front) return;",
                "    if (front == -1) front = 0;",
                "    rear = (rear + 1) % n;",
                "    arr[rear] = x;",
                "}",
                "",
                "void dequeue() {",
                "    if (front == -1) return;",
                "    if (front == rear) front = rear = -1;",
                "    else front = (front + 1) % n;",
                "}",
                "",
                "int main() {",
                "    enqueue(10);",
                "    enqueue(20);",
                "    dequeue();",
                "    enqueue(30);",
                "}"
            ]
        },
        "real_life_examples": [
            "Round-robin scheduling",
            "Circular buffer implementation",
            "Traffic lights",
            "Printer queue"
        ],
        "math_relations": [
            "Cyclic structure representation",
            "Modular arithmetic indexing (i + 1) mod n",
            "circular_queue_definition : CQ = (front, rear, maxSize)",
            "circular_increment : i = (i + 1) mod maxSize",
            "cq_empty_condition : front = rear = -1",
            "cq_full_condition : (rear + 1) mod maxSize = front",
            "cq_length_formula : length = (rear - front + maxSize) mod maxSize"
        ],
        "time_complexity": {
